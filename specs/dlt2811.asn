SetDataSetValues-ErrorPDU ::= SEQUENCE {
    result              [0] IMPLICIT SEQUENCE OF ServiceError
}

-- ====================================================================== --
-- 8.5.3 CreateDataSet (Service Code 0x41) --
-- ====================================================================== --

CreateDataSet-RequestPDU ::= SEQUENCE {
