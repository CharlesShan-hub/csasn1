-- ====================================================================== --
-- 8.12.1 GetFile (Service Code 0x71) --
-- ====================================================================== --

GetFile-RequestPDU ::= SEQUENCE {
    filename        [0] IMPLICIT VisibleString (SIZE (0..255)),
    startPosition   [1] IMPLICIT Int32U
}

GetFile-ResponsePDU ::= SEQUENCE {
    fileData        [0] IMPLICIT OCTET STRING,
    endOfFile       [1] IMPLICIT Boolean DEFAULT 0
}

GetFile-ErrorPDU ::= ServiceError

-- ====================================================================== --
-- 8.12.2 SetFile (Service Code 0x72) --
-- ====================================================================== --

SetFile-RequestPDU ::= SEQUENCE {
    filename        [0] IMPLICIT VisibleString (SIZE (0..255)),
    startPosition   [1] IMPLICIT Int32U,
    fileData        [2] IMPLICIT OCTET STRING,
    endOfFile       [3] IMPLICIT Boolean DEFAULT 0
}

SetFile-ResponsePDU ::= NULL

SetFile-ErrorPDU ::= ServiceError

-- ====================================================================== --
-- 8.12.3 DeleteFile (Service Code 0x73) --
-- ====================================================================== --

DeleteFile-RequestPDU ::= SEQUENCE {
    filename        [0] IMPLICIT VisibleString (SIZE (0..255))
}

DeleteFile-ResponsePDU ::= NULL

DeleteFile-ErrorPDU ::= ServiceError

-- ====================================================================== --
-- 8.12.4 GetFileAttributeValues (Service Code 0x75) --
-- ====================================================================== --

GetFileAttributeValues-RequestPDU ::= SEQUENCE {
    filename        [0] IMPLICIT VisibleString (SIZE (0..255))
}

GetFileAttributeValues-ResponsePDU ::= FileEntry

GetFileAttributeValues-ErrorPDU ::= ServiceError

-- ====================================================================== --
-- 8.12.5 GetFileDirectory (Service Code 0x74) --
-- ====================================================================== --

GetFileDirectory-RequestPDU ::= SEQUENCE {
    pathName        [0] IMPLICIT VisibleString (SIZE (0..255)),
    startTime       [1] IMPLICIT TimeStamp OPTIONAL,
    stopTime        [2] IMPLICIT TimeStamp OPTIONAL,
    fileAfter       [3] IMPLICIT VisibleString (SIZE (0..255)) OPTIONAL
}

GetFileDirectory-ResponsePDU ::= SEQUENCE {
    fileEntry       [0] IMPLICIT SEQUENCE OF FileEntry,
    moreFollows     [1] IMPLICIT Boolean DEFAULT 1
}

GetFileDirectory-ErrorPDU ::= ServiceError

